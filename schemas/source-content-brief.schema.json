{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceContentBrief",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_id", "core_message", "title", "subtitle", "lane", "tags", "rank_items", "visual_direction"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "source_id": { "type": "string", "minLength": 3 },
    "core_message": { "type": "string", "minLength": 10, "maxLength": 120 },
    "title": { "type": "string", "minLength": 8, "maxLength": 32 },
    "subtitle": { "type": "string", "minLength": 8, "maxLength": 45 },
    "lane": { "type": "string", "minLength": 2, "maxLength": 40 },
    "tags": { "type": "array", "minItems": 2, "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 20 } },
    "rank_items": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "name", "reason", "caution", "evidence_ids"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1, "maximum": 4 },
          "name": { "type": "string", "minLength": 2, "maxLength": 18 },
          "reason": { "type": "string", "minLength": 16, "maxLength": 42 },
          "caution": { "type": "string", "minLength": 0, "maxLength": 28 },
          "evidence_ids": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "pattern": "^[ct][0-9]{4}$" } }
        }
      }
    },
    "visual_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["representative_frame", "composition", "objects", "mood"],
      "properties": {
        "representative_frame": { "type": "string", "minLength": 1 },
        "composition": { "type": "string", "minLength": 5, "maxLength": 160 },
        "objects": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "minLength": 1, "maxLength": 30 } },
        "mood": { "type": "string", "minLength": 2, "maxLength": 80 }
      }
    }
  }
}
